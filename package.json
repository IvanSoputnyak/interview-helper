{
  "name": "interview-helper",
  "version": "1.0.0",
  "description": "Native macOS capture + AI analysis + secure mobile viewer",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "mac:native": "swift run --package-path macos-native InterviewHelperMac",
    "mac:app": "bash scripts/assemble-mac-app.sh release && open dist/InterviewHelperMac.app",
    "mac:app:debug": "bash scripts/assemble-mac-app.sh debug && open dist/InterviewHelperMac.app",
    "test": "node --test tests/*.test.js",
    "package:mac": "bash scripts/package-mac.sh",
    "mac:icon": "bash scripts/build-mac-icon.sh macos-native/Resources/AppIcon.icns"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
