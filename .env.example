PORT=3000
# Optional: Swift app only — port in auto base URL when IH_SERVER_BASE_URL is unset (default 3000).
IH_SERVER_PORT=
# Optional: full path to node for the Mac menu “Allow Node through firewall” if PATH is minimal when launching the .app
NODE_BINARY=
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
ANALYZE_PROMPT=
VIEWER_TOKEN=change-this-token
HISTORY_MAX_ITEMS=25
IH_PROJECT_ROOT=
